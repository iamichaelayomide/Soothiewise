generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  THERAPIST
  ADMIN
  ORG_ADMIN
}

enum TriageLevel {
  GREEN
  AMBER
  RED
}

enum SupportNeed {
  LOW
  MODERATE
  HIGH
}

enum SessionFormat {
  TEXT
  AUDIO
  VIDEO
}

enum SessionStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum SubscriptionTier {
  FREE
  PREMIUM
  TEAMS
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum CircleType {
  STUDENTS
  PROFESSIONALS
  MOTHERS
  GRIEF
  MEN
  BREAKUP_RECOVERY
  GENERAL
}

enum ModerationStatus {
  PENDING
  APPROVED
  REMOVED
  ESCALATED
}

enum ConversationMode {
  VENT_AND_REFLECT
  GUIDED_CHECKIN
  SLEEP_WIND_DOWN
  ANXIETY_RESET
  HEARTBREAK_SUPPORT
  BURNOUT_RECOVERY
  GRIEF_REFLECTION
  EXAM_STRESS
  WORK_DECOMPRESSION
  GENERAL
}

enum TonePreference {
  GENTLE
  PRACTICAL
  DIRECT
  FAITH_SENSITIVE
}

enum ContentFormat {
  TEXT
  AUDIO
  VIDEO
  EXERCISE
  JOURNAL_PROMPT
}

enum CrisisSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id                String    @id @default(cuid())
  email             String?   @unique
  emailVerified     DateTime?
  name              String?
  displayName       String?
  image             String?
  role              Role      @default(USER)
  isAnonymous       Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastSeenAt        DateTime?

  profile           Profile?
  accounts          Account[]
  sessions          AuthSession[]
  moodEntries       MoodEntry[]
  journalEntries    JournalEntry[]
  conversations     AIConversation[]
  assessments       Assessment[]
  carePlans         CarePlan[]
  bookings          Booking[]
  subscriptions     Subscription[]
  payments          Payment[]
  notifications     Notification[]
  trustedContacts   TrustedContact[]
  crisisEvents      CrisisEvent[]
  communityPosts    CommunityPost[]
  circleMemberships CircleMembership[]
  languagePrefs     LanguagePreference[]

  @@map("users")
}

model Profile {
  id                String         @id @default(cuid())
  userId            String         @unique
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  age               Int?
  gender            String?
  city              String?
  country           String         @default("Nigeria")
  occupation        String?
  tonePreference    TonePreference @default(GENTLE)
  supportGoals      String[]
  formatPreference  ContentFormat[]
  onboardingDone    Boolean        @default(false)
  onboardingStep    Int            @default(0)
  triageLevel       TriageLevel    @default(GREEN)
  supportNeed       SupportNeed    @default(LOW)
  phq9Score         Int?
  gad7Score         Int?
  burnoutScore      Int?
  sleepScore        Int?

  bio               String?
  avatarUrl         String?
  streakDays        Int            @default(0)
  lastCheckIn       DateTime?

  aiReadJournal     Boolean        @default(false)
  privacySettings   Json           @default("{}")

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@map("profiles")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

model MoodEntry {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  mood          Int
  energy        Int
  sleep         Int
  appetite      Int
  anxiety       Int
  hopefulness   Int
  emoji         String?
  voiceNoteUrl  String?
  note          String?  @db.Text
  triggers      String[]

  recordedAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  @@map("mood_entries")
}

model JournalEntry {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title           String?
  body            String   @db.Text
  promptUsed      String?
  aiSummary       String?  @db.Text
  aiCanRead       Boolean  @default(false)
  isLocked        Boolean  @default(false)
  moodAtEntry     Int?
  tags            String[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("journal_entries")
}

model AIConversation {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  mode        ConversationMode @default(GENERAL)
  title       String?
  summary     String?          @db.Text
  triageLevel TriageLevel?
  isActive    Boolean          @default(true)
  messages    AIMessage[]

  startedAt   DateTime         @default(now())
  endedAt     DateTime?
  updatedAt   DateTime         @updatedAt

  @@map("ai_conversations")
}

model AIMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role           String
  content        String         @db.Text
  tokenCount     Int?
  isFlagged      Boolean        @default(false)
  flagReason     String?
  safetyScore    Float?

  createdAt      DateTime       @default(now())

  @@map("ai_messages")
}

model Assessment {
  id             String      @id @default(cuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  type           String
  responses      Json
  totalScore     Int
  triageLevel    TriageLevel
  supportNeed    SupportNeed
  interpretation String?     @db.Text

  completedAt    DateTime    @default(now())

  @@map("assessments")
}

model CarePlan {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  title         String
  summary       String    @db.Text
  triageLevel   TriageLevel
  durationDays  Int       @default(7)
  modules       Json
  isActive      Boolean   @default(true)
  progress      Int       @default(0)

  generatedAt   DateTime  @default(now())
  expiresAt     DateTime?
  updatedAt     DateTime  @updatedAt

  @@map("care_plans")
}

model Therapist {
  id              String    @id @default(cuid())
  userId          String?   @unique

  name            String
  title           String
  bio             String    @db.Text
  photoUrl        String?
  email           String    @unique
  phone           String?
  city            String
  country         String    @default("Nigeria")

  isVerified      Boolean   @default(false)
  isActive        Boolean   @default(true)

  languages       String[]
  sessionFormats  SessionFormat[]
  pricePerSession Decimal
  currency        String    @default("NGN")

  rating          Float?
  reviewCount     Int       @default(0)

  specialties     TherapistSpecialty[]
  availability    TherapistAvailability[]
  bookings        Booking[]
  sessions        Session[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("therapists")
}

model TherapistSpecialty {
  id           String    @id @default(cuid())
  therapistId  String
  therapist    Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  name         String

  @@map("therapist_specialties")
}

model TherapistAvailability {
  id           String    @id @default(cuid())
  therapistId  String
  therapist    Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  dayOfWeek    Int
  startTime    String
  endTime      String
  timezone     String    @default("Africa/Lagos")

  @@map("therapist_availability")
}

model Booking {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  therapistId   String
  therapist     Therapist     @relation(fields: [therapistId], references: [id])

  format        SessionFormat @default(TEXT)
  scheduledAt   DateTime
  durationMins  Int           @default(50)
  status        SessionStatus @default(SCHEDULED)
  notes         String?       @db.Text
  intakeSummary String?       @db.Text
  paymentId     String?

  session       Session?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("bookings")
}

model Session {
  id             String        @id @default(cuid())
  bookingId      String        @unique
  booking        Booking       @relation(fields: [bookingId], references: [id])
  therapistId    String
  therapist      Therapist     @relation(fields: [therapistId], references: [id])

  startedAt      DateTime?
  endedAt        DateTime?
  status         SessionStatus @default(SCHEDULED)
  therapistNotes String?       @db.Text
  carePlan       String?       @db.Text
  followUpAt     DateTime?
  rating         Int?

  @@map("sessions")
}

model CommunityCircle {
  id           String       @id @default(cuid())
  name         String
  type         CircleType
  description  String       @db.Text
  isModerated  Boolean      @default(true)
  memberCount  Int          @default(0)
  isActive     Boolean      @default(true)

  posts        CommunityPost[]
  memberships  CircleMembership[]

  createdAt    DateTime     @default(now())

  @@map("community_circles")
}

model CircleMembership {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  circleId  String
  circle    CommunityCircle @relation(fields: [circleId], references: [id])
  joinedAt  DateTime        @default(now())

  @@unique([userId, circleId])
  @@map("circle_memberships")
}

model CommunityPost {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id])
  circleId      String
  circle        CommunityCircle  @relation(fields: [circleId], references: [id])

  content       String           @db.Text
  isAnonymous   Boolean          @default(false)
  status        ModerationStatus @default(PENDING)

  flags         ModerationFlag[]

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@map("community_posts")
}

model ModerationFlag {
  id         String           @id @default(cuid())
  postId     String
  post       CommunityPost    @relation(fields: [postId], references: [id])
  reportedBy String?
  reason     String
  status     ModerationStatus @default(PENDING)
  reviewedBy String?
  reviewNote String?
  flaggedAt  DateTime         @default(now())

  @@map("moderation_flags")
}

model Subscription {
  id                 String           @id @default(cuid())
  userId             String
  user               User             @relation(fields: [userId], references: [id])

  tier               SubscriptionTier @default(FREE)
  paystackSubCode    String?          @unique
  status             String
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean          @default(false)

  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@map("subscriptions")
}

model Payment {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])

  amount      Decimal
  currency    String        @default("NGN")
  status      PaymentStatus @default(PENDING)
  paystackRef String?       @unique
  description String?
  metadata    Json?

  paidAt      DateTime?
  createdAt   DateTime      @default(now())

  @@map("payments")
}

model CrisisEvent {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id])

  severity    CrisisSeverity
  trigger     String         @db.Text
  detectedIn  String
  actionTaken String[]
  resolvedAt  DateTime?
  reviewedBy  String?
  notes       String?        @db.Text

  createdAt   DateTime       @default(now())

  @@map("crisis_events")
}

model TrustedContact {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  phone     String?
  email     String?
  relation  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("trusted_contacts")
}

model ContentModule {
  id           String        @id @default(cuid())
  title        String
  description  String        @db.Text
  body         String?       @db.Text
  audioUrl     String?
  videoUrl     String?
  thumbnailUrl String?
  format       ContentFormat
  category     String
  tags         String[]
  intensity    String
  durationMins Int?
  isFeatured   Boolean       @default(false)
  isPublished  Boolean       @default(true)
  order        Int           @default(0)
  createdAt    DateTime      @default(now())

  @@map("content_modules")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@map("notifications")
}

model LanguagePreference {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  language  String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("language_preferences")
}

model Resource {
  id          String   @id @default(cuid())
  title       String
  type        String
  description String?  @db.Text
  phone       String?
  url         String?
  country     String   @default("Nigeria")
  city        String?
  isEmergency Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("resources")
}

model Organization {
  id          String       @id @default(cuid())
  name        String
  type        String
  adminId     String
  accessCode  String       @unique
  teamMembers TeamMember[]
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())

  @@map("organizations")
}

model TeamMember {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  userId         String
  joinedAt       DateTime     @default(now())

  @@unique([organizationId, userId])
  @@map("team_members")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}
